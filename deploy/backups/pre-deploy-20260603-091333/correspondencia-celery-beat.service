[Unit]
Description=Celery Beat - Correspondencia (tareas programadas: correos, rebotes, aprobaciones)
After=network.target redis-server.service
Wants=redis-server.service

[Service]
Type=simple
User=devdiego
Group=www-data
WorkingDirectory=/home/devdiego/Correspondencia-diciembre-1.0
EnvironmentFile=/home/devdiego/Correspondencia-diciembre-1.0/.env
Environment="PATH=/home/devdiego/Correspondencia-diciembre-1.0/venv/bin"
Environment="DJANGO_SETTINGS_MODULE=hospital_document_management.settings"
ExecStart=/home/devdiego/Correspondencia-diciembre-1.0/venv/bin/celery -A hospital_document_management beat -l info
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
