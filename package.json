{
  "name": "correspondencia-tests",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "test:unit": "pytest",
    "test:cov": "pytest --cov",
    "playwright:install": "npx playwright install --with-deps",
    "start:test": "python manage.py runserver 0.0.0.0:8000",
    "test:e2e": "playwright test",
    "test:e2e:ventanilla": "playwright test smoke-ventanilla.spec.ts ventanilla-flujo.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "jest": "^29.7.0",
    "wait-on": "^7.2.0"
  }
}

