// ============================================================================
// MODULO CORRESPONDENCIA - Informes Diarios
// ============================================================================

Table correspondencia_informediariocorrespondencia {
  id integer [primary key]
  fecha date [unique, not null]
  archivo_firmado varchar
  estado varchar [not null, note: 'PENDIENTE, FIRMADO']
  total_correspondencias integer [default: 0]
  fecha_creacion timestamp [not null]
  fecha_subida_firma timestamp
  subido_por_id integer
}

Ref: correspondencia_informediariocorrespondencia.subido_por_id > auth_user.id

Table correspondencia_historialdescargainforme {
  id integer [primary key]
  informe_id integer [not null]
  usuario_id integer
  fecha_descarga timestamp [not null]
  ip_address varchar
}

Ref: correspondencia_historialdescargainforme.informe_id > correspondencia_informediariocorrespondencia.id
Ref: correspondencia_historialdescargainforme.usuario_id > auth_user.id

// ============================================================================
// MODULO CORRESPONDENCIA - Firmas de Correspondencia
// ============================================================================

Table correspondencia_firmacorrespondencia {
  id integer [primary key]
  correspondencia_id integer [unique, not null]
  firma_imagen varchar [not null]
  fecha_firma timestamp [not null]
  firmado_por_id integer
  nombre_firmante varchar [not null]
  cargo_firmante varchar
  oficina_firmante_id integer
  recolector_id integer
  ip_address varchar
  observaciones text
}

Ref: correspondencia_firmacorrespondencia.correspondencia_id - correspondencia_correspondencia.id
Ref: correspondencia_firmacorrespondencia.firmado_por_id > auth_user.id
Ref: correspondencia_firmacorrespondencia.oficina_firmante_id > documentos_oficinaproductora.id
Ref: correspondencia_firmacorrespondencia.recolector_id > auth_user.id

// ============================================================================
// MODULO CORRESPONDENCIA - Comunicaciones Internas (Oficios)
// ============================================================================

Table correspondencia_comunicacioninterna {
  id integer [primary key]
  radicado varchar [unique, note: 'Formato: SIGLA-XX-XXX']
  trd varchar
  fecha_creacion timestamp [not null]
  ciudad varchar [default: 'Saravena']
  fecha_documento date [not null]
  tipo_distribucion varchar [note: 'USUARIO, OFICINA, PROCESO, ENTIDAD']
  es_a_toda_entidad boolean [default: false]
  remitente_usuario_id integer [not null]
  remitente_nombre varchar [not null]
  remitente_cargo varchar
  remitente_oficina_id integer [not null]
  destinatario_oficina_id integer
  destinatario_usuario_id integer
  destinatario_proceso_id integer
  asunto varchar [not null]
  cuerpo text [not null]
  archivo_generado varchar
  archivo_firmado varchar
  fecha_firma timestamp
  revisado_por_id integer
  revisado_nombre varchar
  revisado_cargo varchar
  fecha_revision timestamp
  motivo_rechazo text
  comunicacion_origen_id integer [unique]
  fecha_distribucion timestamp
  estado varchar [not null, note: 'BORRADOR, PENDIENTE_APROBACION, RECHAZADA, APROBADA, DISTRIBUIDA, RESPONDIDA, ANULADA']
}

Ref: correspondencia_comunicacioninterna.remitente_usuario_id > auth_user.id
Ref: correspondencia_comunicacioninterna.remitente_oficina_id > documentos_oficinaproductora.id
Ref: correspondencia_comunicacioninterna.destinatario_oficina_id > documentos_oficinaproductora.id
Ref: correspondencia_comunicacioninterna.destinatario_usuario_id > auth_user.id
Ref: correspondencia_comunicacioninterna.destinatario_proceso_id > documentos_proceso.id
Ref: correspondencia_comunicacioninterna.revisado_por_id > auth_user.id
Ref: correspondencia_comunicacioninterna.comunicacion_origen_id - correspondencia_comunicacioninterna.id

Table correspondencia_comunicacioninternadestinatario {
  id integer [primary key]
  comunicacion_id integer [not null]
  tipo varchar [not null, note: 'USUARIO u OFICINA']
  usuario_id integer
  oficina_id integer
}

Ref: correspondencia_comunicacioninternadestinatario.comunicacion_id > correspondencia_comunicacioninterna.id
Ref: correspondencia_comunicacioninternadestinatario.usuario_id > auth_user.id
Ref: correspondencia_comunicacioninternadestinatario.oficina_id > documentos_oficinaproductora.id

Table correspondencia_comunicacioninternadistribucion {
  id integer [primary key]
  comunicacion_id integer [not null]
  usuario_id integer [not null]
  fecha_distribucion timestamp [not null]
  leido boolean [default: false]
  fecha_lectura timestamp
}

Ref: correspondencia_comunicacioninternadistribucion.comunicacion_id > correspondencia_comunicacioninterna.id
Ref: correspondencia_comunicacioninternadistribucion.usuario_id > auth_user.id

Table correspondencia_historialcomunicacioninterna {
  id integer [primary key]
  comunicacion_id integer [not null]
  evento varchar [not null, note: 'CREADA, EDITADA, APROBADA, RECHAZADA, DISTRIBUIDA, LEIDA, etc.']
  fecha timestamp [not null]
  usuario_id integer
  descripcion text
}

Ref: correspondencia_historialcomunicacioninterna.comunicacion_id > correspondencia_comunicacioninterna.id
Ref: correspondencia_historialcomunicacioninterna.usuario_id > auth_user.id

Table correspondencia_anexocomunicacioninterna {
  id integer [primary key]
  comunicacion_id integer [not null]
  archivo varchar [not null, note: 'PDF, Word o Excel, max 2MB']
  nombre_original varchar
  fecha_carga timestamp [not null]
  subido_por_id integer
}

Ref: correspondencia_anexocomunicacioninterna.comunicacion_id > correspondencia_comunicacioninterna.id
Ref: correspondencia_anexocomunicacioninterna.subido_por_id > auth_user.id

// Referencia de Notificacion a ComunicacionInterna
Ref: correspondencia_notificacion.comunicacion_interna_id > correspondencia_comunicacioninterna.id

// Referencia de CorrespondenciaSalida a GrupoAgenda
Ref: correspondencia_correspondenciasalida.envio_grupo_id > correspondencia_grupoagenda.id
