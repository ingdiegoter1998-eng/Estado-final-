// ============================================================================
// DJANGO AUTH (Usuarios del Sistema)
// ============================================================================

Table auth_user {
  id integer [primary key]
  username varchar [unique, not null]
  first_name varchar
  last_name varchar
  email varchar
  password varchar [not null]
  is_staff boolean
  is_active boolean
  is_superuser boolean
  date_joined timestamp
  last_login timestamp
}

Table auth_group {
  id integer [primary key]
  name varchar [unique, not null, note: 'Ej: Ventanilla, Lider de Oficina, Usuario']
}

Table auth_user_groups {
  id integer [primary key]
  user_id integer [not null]
  group_id integer [not null]
}

Ref: auth_user_groups.user_id > auth_user.id
Ref: auth_user_groups.group_id > auth_group.id

// ============================================================================
// MODULO DOCUMENTOS - Estructura Organizacional
// ============================================================================

Table documentos_entidadproductora {
  id integer [primary key]
  nombre varchar [unique, not null, note: 'Ej: Hospital del Sarare E.S.E.']
}

Table documentos_macroproceso {
  id integer [primary key]
  numero integer [unique, not null]
  nombre varchar [not null, note: 'Ej: ESTRATEGICOS, MISIONALES, DE APOYO']
}

Table documentos_proceso {
  id integer [primary key]
  numero integer [not null]
  nombre varchar [not null]
  sigla varchar [not null, note: 'Ej: DIR, THS, SIG']
  macroproceso_id integer [not null]
}

Ref: documentos_proceso.macroproceso_id > documentos_macroproceso.id

Table documentos_unidadadministrativa {
  id integer [primary key]
  nombre varchar [not null]
  entidad_productora_id integer [not null]
}

Ref: documentos_unidadadministrativa.entidad_productora_id > documentos_entidadproductora.id

Table documentos_oficinaproductora {
  id integer [primary key]
  nombre varchar [not null]
  codigo varchar
  codigo_trd varchar [unique]
  unidad_administrativa_id integer [not null]
  proceso_id integer [not null]
}

Ref: documentos_oficinaproductora.unidad_administrativa_id > documentos_unidadadministrativa.id
Ref: documentos_oficinaproductora.proceso_id > documentos_proceso.id

// ============================================================================
// MODULO DOCUMENTOS - Series y Subseries Documentales (TRD)
