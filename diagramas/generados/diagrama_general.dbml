  codigo_trd char [note: '''Código TRD''', null]
  serie_id foreign_key [null]
  subserie_id foreign_key [null]
  descripcion_documento text [note: '''Descripción del documento (serie/subserie y fecha)''', null]
  tipo_prestamo documentos.char_prestamodocumental_tipo_prestamo [not null]
  estado documentos.char_prestamodocumental_estado [default:`"SOLICITADO"`, not null]
  fecha_solicitud date_time [not null]
  fecha_aprobacion date_time [null]
  fecha_entrega date_time [null]
  fecha_vencimiento date [note: '''Solo para préstamos físicos (10 días hábiles para Historia Clínica, 20 días hábiles para otros)''', null]
  fecha_devolucion date_time [note: '''Fecha en que el usuario devolvió el documento''', null]
  fecha_reintegracion date_time [note: '''Fecha en que Archivo Central reintegró el documento a su ubicación física''', null]
  aprobado_por_id foreign_key [null]
  procesado_por_id foreign_key [null]
  vobo_jefe_nombre char [note: '''Nombre del jefe que aprueba''', default:`"Eliana Gelves"`, null]
  vobo_jefe_cargo char [null]
  vobo_jefe_fecha date [null]
  documento_escaneado file [note: '''PDF escaneado del documento''', null]
  documento_virtual file [note: '''PDF generado para préstamo virtual''', null]
  motivo_rechazo text [null]
  motivo_rechazo_usuario text [note: '''Motivo si el usuario rechaza el documento''', null]
  documento_rechazo file [note: '''Documento adjunto explicando los motivos del rechazo''', null]
  documento_devuelto boolean [default:`False`, not null]
  documento_danado boolean [default:`False`, not null]
  observaciones_dano text [note: '''Observaciones sobre daños o faltantes''', null]
  confirmado_por_usuario boolean [note: '''Usuario confirma que recibió el documento correcto''', default:`False`, not null]
  fecha_confirmacion date_time [null]
  notas text [null]

  indexes {
    (estado,fecha_solicitud) [name: 'documentos__estado_ed1f62_idx', type: btree]
    (solicitante_id,fecha_solicitud) [name: 'documentos__solicit_5cd088_idx', type: btree]
