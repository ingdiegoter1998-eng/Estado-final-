Table documentos_prestamodocumental {
  Note: '''
Modelo principal para préstamos documentales'''

  id big_auto [pk, unique, not null]
  registro_id foreign_key [null]
  fuid_id foreign_key [null]
  solicitante_id foreign_key [not null]
