    (fuid_id) [name: 'documentos_prestamodocumental_fuid_id_b20457f0', type: btree]
    (oficina_responsable_id) [name: 'documentos_prestamodocumental_oficina_responsable_id_60a75584', type: btree]
    (oficina_solicitante_id) [name: 'documentos_prestamodocumental_oficina_solicitante_id_3287c200', type: btree]
    (id) [pk, unique, name: 'documentos_prestamodocumental_pkey', type: btree]
    (procesado_por_id) [name: 'documentos_prestamodocumental_procesado_por_id_2857db24', type: btree]
