Table correspondencia_accesocorrespondenciaoficina {
  Note: '''
Modelo que gestiona los accesos de solo lectura a la correspondencia para oficinas distintas a la destino.'''

  id big_auto [pk, unique, not null]
  correspondencia_id foreign_key [not null]
  oficina_id foreign_key [not null]
  compartido_por_id foreign_key [null]
  fecha_compartido date_time [default:`django.utils.timezone.now()`, not null]
  observaciones text [null]
  leido boolean [note: '''Indica si la oficina abrió por primera vez el detalle.''', default:`False`, not null]
  fecha_lectura date_time [null]
  solo_lider boolean [note: '''Si es True, solo los usuarios del grupo "Lider" de la oficina podrán ver esto.''', default:`True`, not null]
  puede_responder boolean [note: '''Indica si esta oficina externa tiene permiso para generar respuestas.''', default:`False`, not null]

  indexes {
    (compartido_por_id) [name: 'correspondencia_accesocorrespondenciaoficina_compartido_por_id_81adc962', type: btree]
    (correspondencia_id) [name: 'correspondencia_accesocorrespondenciaoficina_correspondencia_id_ad00abf6', type: btree]
    (oficina_id) [name: 'correspondencia_accesocorrespondenciaoficina_oficina_id_9126b1d3', type: btree]
    (id) [pk, unique, name: 'correspondencia_accesocorrespondenciaoficina_pkey', type: btree]
  }
}
ref: correspondencia_accesocorrespondenciaoficina.correspondencia_id > correspondencia_correspondencia.id
ref: correspondencia_accesocorrespondenciaoficina.oficina_id > documentos_oficinaproductora.id
ref: correspondencia_accesocorrespondenciaoficina.compartido_por_id > auth_user.id


