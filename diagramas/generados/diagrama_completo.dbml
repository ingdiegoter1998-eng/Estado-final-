Table correspondencia_comunicacioninterna {
  Note: '''
Modelo para gestionar las comunicaciones internas (Oficios) entre oficinas.
Genera un documento Word basado en plantilla.

Flujo de estados:
- BORRADOR: Usuario puede editar.
- PENDIENTE_APROBACION: Esperando aprobación del líder.
- RECHAZADA: Líder rechazó. Fin del flujo.
- APROBADA: Líder aprobó. Si es a toda la entidad, requiere firma antes de distribuir.
- DISTRIBUIDA: Comunicación enviada a destinatarios.
- RESPONDIDA: Se creó una respuesta a esta comunicación.'''

  id big_auto [pk, unique, not null]
  radicado char [unique, null]
  codigo_dependencia char [note: '''Código jerárquico de la dependencia/oficina productora''', null]
  anio_radicado positive_small_integer [null]
  consecutivo_radicado positive_integer [null]
  serie_documental_id foreign_key [note: '''Serie documental asociada a la comunicación interna''', null]
  subserie_documental_id foreign_key [note: '''Subserie documental asociada a la comunicación interna''', null]
  trd char [note: '''Código TRD (Tabla de Retención Documental)''', null]
  fecha_creacion date_time [not null]
  ciudad char [default:`"Saravena"`, not null]
  fecha_documento date [note: '''Fecha que aparecerá en el documento impreso''', not null]
  tipo_distribucion correspondencia.char_comunicacioninterna_tipo_distribucion [note: '''Tipo de distribución de la comunicación''', default:`"USUARIO"`, null]
  es_a_toda_entidad boolean [note: '''Si es True, va a todos los usuarios del sistema y requiere firma digital. (DEPRECADO: usar tipo_distribucion="ENTIDAD")''', default:`False`, not null]
  remitente_usuario_id foreign_key [not null]
  remitente_nombre char [not null]
  remitente_cargo char [null]
  remitente_oficina_id foreign_key [not null]
  destinatario_oficina_id foreign_key [note: '''Oficina destino. Dejar vacío si es a toda la entidad.''', null]
  destinatario_usuario_id foreign_key [note: '''Opcional: Si va dirigido a una persona específica''', null]
  destinatario_proceso_id foreign_key [note: '''Proceso destino (solo cuando tipo_distribucion = "PROCESO")''', null]
  asunto char [not null]
  cuerpo text [note: '''Contenido principal de la comunicación''', not null]
  archivo_generado file [null]
  archivo_firmado file [note: '''PDF firmado digitalmente por el líder (requerido para distribución a oficina/proceso/entidad)''', null]
  fecha_firma date_time [note: '''Fecha y hora en que se subió el archivo firmado''', null]
  revisado_por_id foreign_key [note: '''Líder de oficina que revisó y aprobó la comunicación''', null]
  revisado_nombre char [note: '''Nombre del revisor (snapshot)''', null]
  revisado_cargo char [note: '''Cargo del revisor (snapshot)''', null]
  fecha_revision date_time [note: '''Fecha y hora de revisión/aprobación''', null]
  motivo_rechazo text [note: '''Motivo del rechazo (si aplica)''', null]
  comunicacion_origen_id foreign_key [note: '''Comunicación original a la que responde (múltiples respuestas permitidas)''', null]
  es_respuesta_destacada boolean [note: '''Indica si esta respuesta está destacada (estrellita). Líderes y usuarios asignados inicialmente tienen respuestas destacadas.''', default:`False`, not null]
  fecha_distribucion date_time [note: '''Fecha y hora de distribución''', null]
  estado correspondencia.char_comunicacioninterna_estado [default:`"BORRADOR"`, not null]

  indexes {
    (comunicacion_origen_id) [name: 'correspondencia_comunicacioninterna_comunicacion_origen_id_aa179bcb', type: btree]
    (destinatario_oficina_id) [name: 'correspondencia_comunicacioninterna_destinatario_oficina_id_a9729f2a', type: btree]
    (destinatario_proceso_id) [name: 'correspondencia_comunicacioninterna_destinatario_proceso_id_0fc7fcea', type: btree]
    (destinatario_usuario_id) [name: 'correspondencia_comunicacioninterna_destinatario_usuario_id_76c0596c', type: btree]
    (id) [pk, unique, name: 'correspondencia_comunicacioninterna_pkey', type: btree]
    (radicado) [unique, name: 'correspondencia_comunicacioninterna_radicado_key', type: btree]
    (remitente_oficina_id) [name: 'correspondencia_comunicacioninterna_remitente_oficina_id_235f04fd', type: btree]
    (remitente_usuario_id) [name: 'correspondencia_comunicacioninterna_remitente_usuario_id_d29c0f24', type: btree]
    (revisado_por_id) [name: 'correspondencia_comunicacioninterna_revisado_por_id_bd9d7cea', type: btree]
    (serie_documental_id) [name: 'correspondencia_comunicacioninterna_serie_documental_id_f5c71249', type: btree]
    (subserie_documental_id) [name: 'correspondencia_comunicacioninterna_subserie_documental_id_7039d29b', type: btree]
  }
}
