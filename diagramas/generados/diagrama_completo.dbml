  remitente email [not null]
  asunto char [not null]
  cuerpo_texto text [note: '''Cuerpo del mensaje en texto plano''', not null]
  cuerpo_html text [note: '''Cuerpo del mensaje en HTML (si existe)''', not null]
  fecha_recepcion_original date_time [note: '''Fecha del encabezado "Date" del correo''', null]
  fecha_recibida_gmail date_time [note: '''Fecha INTERNALDATE registrada por Gmail/IMAP (recepción en servidor)''', null]
  fecha_lectura_imap date_time [default:`django.utils.timezone.now()`, not null]
  procesado boolean [note: '''Indica si ya se intentó la clasificación IA''', default:`False`, not null]
  radicado_asociado_id foreign_key [note: '''Correspondencia creada a partir de este correo (si aplica)''', null]
  urgencia_asociada_id foreign_key [note: '''Urgencia creada a partir de este correo (si aplica)''', null]
  requiere_revision_manual boolean [note: '''Marcar si la radicación automática falló y necesita intervención.''', default:`False`, not null]
  en_papelera boolean [note: '''En papelera: no se muestra en bandeja activa; se conserva para registro.''', default:`False`, not null]
  motivo_papelera correspondencia.char_correoentrante_motivo_papelera [note: '''Motivo por el cual se envió a papelera.''', not null]
  fecha_papelera date_time [note: '''Fecha en que se envió a papelera.''', null]
  usuario_papelera_id foreign_key [note: '''Usuario que envió el correo a papelera.''', null]
  oficina_clasificada_id foreign_key [note: '''Oficina destino predicha por IA''', null]
  serie_clasificada_id foreign_key [note: '''Serie documental predicha por IA''', null]
  subserie_clasificada_id foreign_key [note: '''Subserie documental predicha por IA (relacionada a la serie)''', null]
  fecha_clasificacion date_time [note: '''Fecha y hora en que se realizó la clasificación IA''', null]

  indexes {
    (en_papelera) [name: 'correspondencia_correoentrante_en_papelera_3123abbe', type: btree]
