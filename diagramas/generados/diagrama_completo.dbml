Table correspondencia_correspondencia {
  Note: '''
Modelo principal para gestionar la correspondencia entrante del sistema.

Este modelo centraliza toda la información relacionada con documentos
que ingresan a la entidad, incluyendo su radicación, asignación, seguimiento
y cálculo automático de plazos de respuesta (SLA).

Características principales:
- Generación automática de números de radicado
- Cálculo y persistencia de plazos SLA basados en TRD o configuración
- Trazabilidad completa del flujo de correspondencia
- Integración con calendario laboral para cálculos de fechas límite

Attributes:
numero_radicado (str): Número único generado automáticamente
tipo_radicado (str): Tipo de radicado (ENTRANTE, etc.)
fecha_radicacion (datetime): Fecha y hora de radicación
usuario_radicador (User): Usuario que realizó la radicación
remitente (Contacto): Contacto externo que envió la correspondencia
asunto (str): Descripción del contenido de la correspondencia
medio_recepcion (str): Medio por el cual llegó (FISICO/ELECTRONICO)
requiere_respuesta (bool): Indica si requiere respuesta
tiempo_respuesta (str): Configuración de tiempo (NORMAL/URGENTE/MUY_URGENTE)
oficina_destino (OficinaProductora): Oficina responsable de procesar
serie/subserie (FK): Clasificación documental
estado (str): Estado actual en el flujo de trabajo
usuario_destino_inicial (User): Usuario asignado inicialmente
leido_por_oficina (bool): Indica si fue leído por la oficina
fecha_limite_respuesta (datetime): Fecha límite calculada dinámicamente
plazo_respuesta_dias (int): Días hábiles persistidos para reportes
fecha_limite_respuesta_persist (datetime): Fecha límite persistida
plazo_origen (str): Origen del plazo (TRD/FALLBACK/NONE)
tramite_aplicado (TramiteTipo): Trámite aplicado si hay TRD'''

  id big_auto [pk, unique, not null]
  numero_radicado char [unique, not null]
  tipo_radicado correspondencia.char_correspondencia_tipo_radicado [default:`"ENTRANTE"`, not null]
  fecha_radicacion date_time [default:`django.utils.timezone.now()`, not null]
  usuario_radicador_id foreign_key [null]
  remitente_id foreign_key [note: '''Seleccione el contacto (persona) que envía''', null]
  asunto text [not null]
  serie_id foreign_key [null]
  subserie_id foreign_key [null]
  medio_recepcion correspondencia.char_correspondencia_medio_recepcion [default:`"FISICO"`, not null]
  requiere_respuesta boolean [default:`False`, not null]
  tiempo_respuesta correspondencia.char_correspondencia_tiempo_respuesta [null]
  dias_personalizados integer [note: '''Días de respuesta personalizados (1-15). Si se especifica, tiene prioridad sobre tiempo_respuesta y TRD.''', null]
  plazo_respuesta_dias integer [null]
  fecha_limite_respuesta_persist date_time [null]
  plazo_origen correspondencia.char_correspondencia_plazo_origen [default:`"NONE"`, not null]
  tramite_aplicado_id foreign_key [null]
  estado correspondencia.char_correspondencia_estado [default:`"RADICADA"`, not null]
  leido_por_oficina boolean [note: '''Indica si alguien de la oficina destino ya lo leyó''', default:`False`, not null]
  resumen_ia text [note: '''Resumen del contenido generado por IA''', null]
  sellado boolean [note: '''Indica si el documento físico ya fue sellado/imprimido''', default:`False`, not null]
  fecha_sellado date_time [note: '''Fecha y hora del primer sellado''', null]
  en_planilla boolean [note: '''Indica si esta correspondencia ya fue descargada e incluida en una planilla''', default:`False`, not null]
  oficina_destino_id foreign_key [not null]
  usuario_destino_inicial_id foreign_key [null]
  origen_radicacion correspondencia.char_correspondencia_origen_radicacion [note: '''Indica cómo fue radicada esta correspondencia''', default:`"NORMAL"`, not null]
  fecha_recepcion_documento date [note: '''Fecha en que se recibió físicamente el documento (importante para calcular plazo de respuesta)''', null]
  tipo_tramite correspondencia.char_correspondencia_tipo_tramite [note: '''Tipo de trámite (radicación rápida)''', null]
  entidad_persona_remitente char [null]
  funcionario_responsable_tramite char [null]
  email_funcionario_responsable email [note: '''Correo electrónico del funcionario responsable del trámite''', null]
  clasificacion_comunicacion char [null]
  numero_folios positive_integer [null]
  anexos char [null]
  medio_recibido correspondencia.char_correspondencia_medio_recibido [null]
  direccion_correo_remitente email [null]
  empresa_transportadora char [null]
  numero_guia char [null]
  fecha_limite_respuesta_manual date [null]
  fecha_primer_seguimiento date [null]
  fecha_segundo_seguimiento date [null]
  fecha_notificacion_vencimiento date [null]
  fecha_respuesta date [null]
  estado_respuesta correspondencia.char_correspondencia_estado_respuesta [note: '''Solo para radicación rápida: Pendiente, Respondida o Vencida.''', null]
  radicado_enviado_respuesta char [null]

  indexes {
    (en_planilla) [name: 'correspondencia_correspondencia_en_planilla_a9e663aa', type: btree]
    (numero_radicado) [unique, name: 'correspondencia_correspondencia_numero_radicado_key', type: btree]
    (oficina_destino_id) [name: 'correspondencia_correspondencia_oficina_destino_id_60db489f', type: btree]
    (origen_radicacion) [name: 'correspondencia_correspondencia_origen_radicacion_4306106d', type: btree]
    (id) [pk, unique, name: 'correspondencia_correspondencia_pkey', type: btree]
    (remitente_id) [name: 'correspondencia_correspondencia_remitente_id_44d41cc7', type: btree]
    (sellado) [name: 'correspondencia_correspondencia_sellado_694cf705', type: btree]
    (serie_id) [name: 'correspondencia_correspondencia_serie_id_ad01d4fe', type: btree]
    (subserie_id) [name: 'correspondencia_correspondencia_subserie_id_b2cf9819', type: btree]
    (tramite_aplicado_id) [name: 'correspondencia_correspondencia_tramite_aplicado_id_02f4a3bb', type: btree]
    (usuario_destino_inicial_id) [name: 'correspondencia_correspondencia_usuario_destino_inicial_id_2eeff7e8', type: btree]
    (usuario_radicador_id) [name: 'correspondencia_correspondencia_usuario_radicador_id_b84999ee', type: btree]
  }
}
