Table correspondencia_anexocomunicacioninterna {
  Note: '''
Modelo para almacenar anexos adjuntos a comunicaciones internas.
Permite adjuntar archivos Word, PDF o Excel.
Límite: 10 anexos por comunicación, 25MB por archivo, 25MB total.'''

  id big_auto [pk, unique, not null]
  comunicacion_id foreign_key [note: '''Comunicación interna a la que pertenece este anexo''', not null]
  archivo file [note: '''Archivo anexo (PDF, Word o Excel)''', not null]
  nombre_original char [note: '''Nombre original del archivo''', not null]
  fecha_carga date_time [note: '''Fecha y hora en que se subió el archivo''', not null]
