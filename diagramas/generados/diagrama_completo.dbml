Table adjuntos_urgencia {
  Note: '''
Adjuntos de respuestas de urgencias'''

  id big_auto [pk, unique, not null]
  urgencia_id foreign_key [not null]
  archivo file [not null]
  nombre_original char [not null]
  tipo_mime char [not null]
  tamaño_bytes positive_integer [default:`0`, not null]
  fecha_carga date_time [not null]
  subido_por_id foreign_key [null]

  indexes {
    (id) [pk, unique, name: 'adjuntos_urgencia_pkey', type: btree]
    (subido_por_id) [name: 'adjuntos_urgencia_subido_por_id_dc4c9da3', type: btree]
    (urgencia_id) [name: 'adjuntos_urgencia_urgencia_id_b99d4be5', type: btree]
  }
}
ref: adjuntos_urgencia.urgencia_id > correspondencia_urgencia.id
ref: adjuntos_urgencia.subido_por_id > auth_user.id


Table asistente_chunk {
  Note: '''
Fragmento indexado de un documento fuente.'''

  id big_auto [pk, unique, not null]
  documento_id foreign_key [not null]
  orden positive_integer [not null]
  heading char [not null]
  contenido text [not null]
  search_text text [not null]
  metadata json [default:`builtins.dict()`, not null]

  indexes {
    (documento_id) [name: 'asistente_chunk_documento_id_2939de56', type: btree]
    (documento_id,orden) [unique, name: 'asistente_chunk_documento_id_orden_d0f881bd_uniq', type: btree]
    (id) [pk, unique, name: 'asistente_chunk_pkey', type: btree]
  }
}
ref: asistente_chunk.documento_id > asistente_documento.id


Table asistente_conversacion {
  Note: '''
Sesión de conversación del asistente documental.'''

  id big_auto [pk, unique, not null]
  usuario_id foreign_key [not null]
  titulo char [default:`"Nueva conversación"`, not null]
  estado asistente.char_conversacion_estado [default:`"ACTIVA"`, not null]
  ultima_pregunta_at date_time [null]
  creado_en date_time [not null]
  actualizado_en date_time [not null]

  indexes {
    (id) [pk, unique, name: 'asistente_conversacion_pkey', type: btree]
    (usuario_id) [name: 'asistente_conversacion_usuario_id_1ae4151f', type: btree]
  }
}
ref: asistente_conversacion.usuario_id > auth_user.id


Table asistente_documento {
  Note: '''
Documento fuente indexado para recuperación documental.'''

  id big_auto [pk, unique, not null]
  ruta_relativa char [unique, not null]
  titulo char [not null]
  checksum char [not null]
  tipo_fuente char [default:`"archivo"`, not null]
  activo boolean [default:`True`, not null]
  metadata json [default:`builtins.dict()`, not null]
  indexado_en date_time [not null]

  indexes {
    (id) [pk, unique, name: 'asistente_documento_pkey', type: btree]
    (ruta_relativa) [unique, name: 'asistente_documento_ruta_relativa_key', type: btree]
  }
}


