Table documentos_proceso {
  Note: '''
Proceso organizacional que pertenece a un macroproceso'''

  id big_auto [pk, unique, not null]
  numero integer [note: '''Número del proceso''', not null]
  nombre char [note: '''Nombre del proceso''', not null]
  sigla char [note: '''Sigla del proceso (ej: DIR, THS, SIG)''', not null]
  macroproceso_id foreign_key [not null]

  indexes {
    (macroproceso_id) [name: 'documentos_proceso_macroproceso_id_aba1b422', type: btree]
    (numero,macroproceso_id) [unique, name: 'documentos_proceso_numero_macroproceso_id_7c4d3e85_uniq', type: btree]
    (id) [pk, unique, name: 'documentos_proceso_pkey', type: btree]
  }
}
