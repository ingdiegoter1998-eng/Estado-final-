enum documentos.char_despliegueoficina_estado_visita {
  "pendiente" [note: '''Pendiente de visita''']
  "visitada" [note: '''Visitada''']
  "capacitada" [note: '''Capacitada''']
  "no_aplica" [note: '''No aplica''']
}

enum documentos.char_perfilusuario_tipo_documento {
  "CC" [note: '''Cédula de Ciudadanía''']
  "CE" [note: '''Cédula de Extranjería''']
  "TI" [note: '''Tarjeta de Identidad''']
  "PA" [note: '''Pasaporte''']
  "RC" [note: '''Registro Civil''']
  "NIT" [note: '''NIT''']
  "PEP" [note: '''Permiso Especial de Permanencia''']
  "PPT" [note: '''Permiso por Protección Temporal''']
}

enum documentos.char_prestamodocumental_estado {
  "SOLICITADO" [note: '''Solicitado''']
  "ENTREGADO" [note: '''Entregado''']
  "PRESTAMO_ACTIVO" [note: '''Préstamo Activo''']
  "DEVOLUCION_SOLICITADA" [note: '''Devolución Solicitada''']
  "DEVUELTO" [note: '''Devuelto''']
  "REINTEGRADO" [note: '''Reintegrado''']
  "RECHAZADO" [note: '''Rechazado''']
  "RECHAZADO_USUARIO" [note: '''Rechazado por Usuario''']
  "VENCIDO" [note: '''Vencido''']
}

enum documentos.char_prestamodocumental_tipo_prestamo {
  "FISICO" [note: '''Físico''']
  "VIRTUAL" [note: '''Virtual''']
}

